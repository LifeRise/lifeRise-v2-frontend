# LifeRise Enterprise Monorepo — .gitignore
# Patterns without a leading / match anywhere in the tree (apps/web/, apps/api/, etc.)
# See https://help.github.com/articles/ignoring-files/

# ── Node / npm ────────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Next.js (apps/web) ────────────────────────────────────────────────────────
.next/
out/
next-env.d.ts

# ── Go backend (apps/api) ─────────────────────────────────────────────────────
# Compiled binaries
apps/api/build/
*.exe
*.exe~

# Go test/coverage output
coverage.out
coverage/

# Backend config with secrets (copy from config.example.yaml)
apps/api/config.yaml

# ── General build artefacts ───────────────────────────────────────────────────
*.tsbuildinfo
dist/

# ── Environment / secrets ─────────────────────────────────────────────────────
.env*
# Allow committing example/template env files (they contain only placeholders)
!.env*.example
!**/.env*.example

# ── Vercel ────────────────────────────────────────────────────────────────────
.vercel

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
*.pem
Thumbs.db
