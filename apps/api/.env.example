# LifeRise Backend Environment Variables
# Copy this file to .env and fill in your real values.
# DO NOT COMMIT .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase PostgreSQL direct connection or pooler URL
LIFERISE_DATABASE_URL=postgres://postgres:[password]@db.[ref].supabase.co:5432/postgres?sslmode=require

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters and consistent across api/vendor-api/admin-api
LIFERISE_JWT_SECRET=change-me-to-a-random-32-char-string

# ── Supabase ──────────────────────────────────────────────────────────────────
LIFERISE_SUPABASE_PROJECT_REF=your-project-ref
LIFERISE_SUPABASE_PROJECT_URL=https://your-project-ref.supabase.co
LIFERISE_SUPABASE_ANON_KEY=your-anon-key
LIFERISE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────────
LIFERISE_STRIPE_SECRET_KEY=
LIFERISE_STRIPE_PUBLISHABLE_KEY=
LIFERISE_STRIPE_WEBHOOK_SECRET=
LIFERISE_STRIPE_OAUTH_CLIENT_ID=

# ── Firebase ──────────────────────────────────────────────────────────────────
LIFERISE_FIREBASE_PROJECT_ID=
LIFERISE_FIREBASE_DATABASE_URL=
LIFERISE_FIREBASE_STORAGE_BUCKET=
LIFERISE_FIREBASE_API_KEY=
LIFERISE_FIREBASE_AUTH_DOMAIN=
LIFERISE_FIREBASE_MESSAGING_SENDER_ID=
LIFERISE_FIREBASE_APP_ID=
LIFERISE_FIREBASE_VAPID_KEY=
LIFERISE_FIREBASE_MEASUREMENT_ID=

# ── Mail (SMTP or Resend) ─────────────────────────────────────────────────────
# Driver: "smtp" (default) or "resend"
LIFERISE_MAIL_DRIVER=smtp
LIFERISE_MAIL_HOST=
LIFERISE_MAIL_USERNAME=
LIFERISE_MAIL_PASSWORD=
LIFERISE_MAIL_FROM_ADDRESS=
LIFERISE_MAIL_FROM_NAME=LifeRise
# Resend API key (only needed when driver=resend)
LIFERISE_MAIL_RESEND_API_KEY=

# ── Redis ─────────────────────────────────────────────────────────────────────
LIFERISE_REDIS_HOST=127.0.0.1
LIFERISE_REDIS_PORT=6379
LIFERISE_REDIS_PASSWORD=
LIFERISE_REDIS_DB=0

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated. Add your Vercel URL for production.
LIFERISE_CORS_ALLOW_ORIGINS=http://localhost:3000
