# LifeRise Web — Environment Variable Template
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# After the monorepo migration this file lives at:  apps/web/.env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Go Backend API URLs ───────────────────────────────────────────────────────
# All three default to localhost:8080 (single-binary dev mode) if omitted.
# Set all three when running the three-binary production setup.

NEXT_PUBLIC_API_URL=http://localhost:8080          # Customer/resident API
NEXT_PUBLIC_VENDOR_API_URL=http://localhost:8081   # Vendor API
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8082    # Manager/admin API

# ── Supabase (optional) ───────────────────────────────────────────────────────
# Leave blank to use mock localStorage auth (offline/demo mode).
# When set, auth goes: Go JWT → Supabase session → mock fallback.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — NEVER prefix with NEXT_PUBLIC_
# Used only in Next.js Route Handlers / Server Actions (not client components).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
